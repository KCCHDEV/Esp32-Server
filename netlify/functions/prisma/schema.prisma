// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NETLIFY_DATABASE_URL")
}

model User {
  id                      String    @id @default(cuid())
  username                String    @unique
  email                   String    @unique
  password                String
  role                    Role      @default(USER)
  subscription            Subscription @default(FREE)
  subscriptionExpiry      DateTime?
  deviceLimit             Int       @default(3)
  projectLimit            Int       @default(5)
  storageLimit            Int       @default(100) // MB
  isActive                Boolean   @default(true)
  lastLogin               DateTime  @default(now())
  loginAttempts           Int       @default(0)
  lockUntil               DateTime?
  resetPasswordToken      String?
  resetPasswordExpire     DateTime?
  emailVerified           Boolean   @default(false)
  emailVerificationToken  String?
  emailVerificationExpire DateTime?
  twoFactorEnabled        Boolean   @default(false)
  twoFactorSecret         String?
  backupCodes             String[]
  profilePicture          String?
  timezone                String    @default("UTC")
  language                String    @default("en")
  notificationSettings   Json      @default("{\"email\": true, \"push\": true}")
  lastPasswordChange      DateTime  @default(now())
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  devices                 Device[]
  projects                Project[]
  sharedProjects          ProjectShare[]
  auditLogs               AuditLog[]
  sessions                UserSession[]

  @@map("users")
}

model Device {
  id                String    @id @default(cuid())
  name              String
  description       String?
  userId            String
  deviceId          String    @unique @default(cuid())
  apiKey            String    @unique
  isOnline          Boolean   @default(false)
  lastSeen          DateTime  @default(now())
  firmwareVersion   String    @default("1.0.0")
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // WiFi Configuration
  wifiSsid          String?
  wifiConnected     Boolean   @default(false)
  wifiSignalStrength Int?
  wifiIpAddress     String?

  // Hardware Information
  chipModel         String?
  flashSize         String?
  cpuFreq           Int?
  freeHeap          Int?
  usedHeap          Int?

  // Location
  locationName      String?
  locationLat       Float?
  locationLng       Float?

  // Statistics
  totalUptime       Int       @default(0)
  restartCount      Int       @default(0)
  lastRestart       DateTime?

  // Tags
  tags              String[]

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects          Project[]
  pins              Pin[]
  sensors           Sensor[]
  actuators         Actuator[]
  i2cDevices        I2CDevice[]

  @@map("devices")
}

model Pin {
  id        String    @id @default(cuid())
  deviceId  String
  number    Int
  mode      PinMode   @default(INPUT)
  value     Float     @default(0)
  label     String?
  isUsed    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, number])
  @@map("pins")
}

model Sensor {
  id        String    @id @default(cuid())
  deviceId  String
  type      String
  pin       Int?
  name      String
  value     Float?
  unit      String?
  lastRead  DateTime?
  config    Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("sensors")
}

model Actuator {
  id        String    @id @default(cuid())
  deviceId  String
  type      String
  pin       Int
  name      String
  state     Json?
  config    Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("actuators")
}

model I2CDevice {
  id          String    @id @default(cuid())
  deviceId    String
  address     String
  name        String?
  type        String?
  isConnected Boolean   @default(false)
  lastRead    DateTime?
  data        Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, address])
  @@map("i2c_devices")
}

model Project {
  id            String          @id @default(cuid())
  name          String
  description   String?
  userId        String
  deviceId      String
  isActive      Boolean         @default(false)
  version       Int             @default(1)
  category      ProjectCategory @default(OTHER)
  tags          String[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Canvas Configuration
  canvasBlocks      Json?
  canvasConnections Json?
  canvasVariables   Json?
  canvasFunctions   Json?

  // Generated Code
  generatedCode     String?
  lastGenerated     DateTime?

  // Deployment
  isDeployed        Boolean         @default(false)
  deployedAt        DateTime?
  deploymentVersion Int             @default(1)
  deploymentStatus  DeploymentStatus @default(PENDING)

  // Scheduling
  schedulingEnabled     Boolean @default(false)
  schedulingType        SchedulingType @default(INTERVAL)
  schedulingInterval    Int?
  schedulingCron        String?
  schedulingEventTriggers String[]

  // Monitoring
  monitoringEnabled     Boolean @default(true)
  monitoringLogLevel    LogLevel @default(INFO)
  monitoringAlertsEnabled Boolean @default(false)

  // Sharing
  isPublic          Boolean @default(false)
  publicUrl         String?

  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  device            Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  sharedWith        ProjectShare[]
  metrics           ProjectMetric[]

  @@map("projects")
}

model ProjectShare {
  id         String           @id @default(cuid())
  projectId  String
  userId     String
  permission SharePermission  @default(VIEW)
  createdAt  DateTime         @default(now())

  // Relations
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_shares")
}

model ProjectMetric {
  id        String   @id @default(cuid())
  projectId String
  name      String
  value     Float
  unit      String?
  timestamp DateTime @default(now())

  // Relations
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_metrics")
}

// Enums
enum Role {
  USER
  ADMIN
}

enum Subscription {
  FREE
  PREMIUM
}

enum PinMode {
  INPUT
  OUTPUT
  INPUT_PULLUP
  INPUT_PULLDOWN
  ANALOG_INPUT
  PWM_OUTPUT
  I2C_SDA
  I2C_SCL
}

enum ProjectCategory {
  AUTOMATION
  MONITORING
  CONTROL
  IOT
  SENSOR
  DISPLAY
  COMMUNICATION
  OTHER
}

enum DeploymentStatus {
  PENDING
  DEPLOYED
  FAILED
  STOPPED
}

enum SchedulingType {
  INTERVAL
  CRON
  EVENT
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum SharePermission {
  VIEW
  EDIT
}

// Audit logging for security and compliance
model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  action      String    // LOGIN, LOGOUT, CREATE_DEVICE, DELETE_PROJECT, etc.
  resource    String?   // Resource affected (device ID, project ID, etc.)
  details     Json?     // Additional details about the action
  ipAddress   String?
  userAgent   String?
  success     Boolean   @default(true)
  errorMessage String?
  createdAt   DateTime  @default(now())

  // Relations
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// User session management
model UserSession {
  id          String    @id @default(cuid())
  userId      String
  sessionToken String   @unique
  deviceInfo  Json?     // Browser, OS, device info
  ipAddress   String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  lastUsed    DateTime  @default(now())

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
}

// System-wide settings and configuration
model SystemSetting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       Json
  description String?
  isPublic    Boolean   @default(false) // If true, can be accessed by frontend
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("system_settings")
}

// API rate limiting and monitoring
model ApiUsage {
  id          String    @id @default(cuid())
  userId      String?
  endpoint    String
  method      String
  statusCode  Int
  responseTime Int      // milliseconds
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@map("api_usage")
  @@index([userId])
  @@index([endpoint])
  @@index([createdAt])
}

// File storage tracking
model FileStorage {
  id          String    @id @default(cuid())
  userId      String
  filename    String
  originalName String
  mimeType    String
  size        Int       // bytes
  path        String
  purpose     String    // PROFILE_PICTURE, PROJECT_ASSET, FIRMWARE, etc.
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("file_storage")
  @@index([userId])
  @@index([purpose])
}