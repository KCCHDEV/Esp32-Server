# WebSocket Configuration
# Set to 'true' to enable Socket.IO connections in production/serverless environments
# Leave empty or set to 'false' to disable WebSocket connections
REACT_APP_ENABLE_SOCKET=

# Custom Socket.IO server URL (optional)
# If not set, defaults to http://localhost:3001 in development
# In production, only used when REACT_APP_ENABLE_SOCKET=true
REACT_APP_SOCKET_URL=

# Examples:
# For local development with backend server:
# REACT_APP_ENABLE_SOCKET=true
# REACT_APP_SOCKET_URL=http://localhost:3001

# For production with external Socket.IO server:
# REACT_APP_ENABLE_SOCKET=true
# REACT_APP_SOCKET_URL=wss://your-socketio-server.com

# For serverless deployment (Netlify) - disable WebSockets:
# REACT_APP_ENABLE_SOCKET=false
# (or leave empty)