# =============================================================================
# ESP32 Zero Code Platform - Environment Variables
# =============================================================================

# Database Configuration (Neon PostgreSQL)
# =============================================================================
# For development - use standard Prisma variables
DATABASE_URL="postgresql://username:password@ep-example-123456.us-east-1.aws.neon.tech/database_name?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-example-123456.us-east-1.aws.neon.tech/database_name?sslmode=require"

# For Netlify deployment - these will be provided automatically by Neon extension
# NETLIFY_DATABASE_URL="postgresql://username:password@ep-example-123456.us-east-1.aws.neon.tech/database_name?sslmode=require"
# NETLIFY_DATABASE_URL_UNPOOLED="postgresql://username:password@ep-example-123456.us-east-1.aws.neon.tech/database_name?sslmode=require"

# JWT Configuration
# =============================================================================
# Secret key for signing JWT tokens (generate a strong random string)
JWT_SECRET="your-super-secure-jwt-secret-key-here-use-crypto-random-256-bits"

# JWT token expiration time (examples: 1h, 24h, 7d, 30d)
JWT_EXPIRE="7d"

# Server Configuration
# =============================================================================
# Port for the Express server (development only, Netlify handles this in production)
PORT=3001

# Node environment
NODE_ENV="development"

# CORS Configuration
# =============================================================================
# Frontend URL for CORS (development)
CORS_ORIGIN="http://localhost:3000"

# Production frontend URL (for Netlify deployment)
CORS_ORIGIN_PROD="https://your-app-name.netlify.app"

# Rate Limiting
# =============================================================================
# Rate limit window in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Optional - for email verification and reset passwords)
# =============================================================================
# SMTP settings for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Email addresses
FROM_EMAIL="noreply@yourapp.com"
FROM_NAME="ESP32 Zero Code Platform"

# File Upload Configuration
# =============================================================================
# Maximum file size for uploads (in bytes)
MAX_FILE_SIZE=10485760

# Upload directory (relative to backend root)
UPLOAD_DIR="uploads"

# Security Configuration
# =============================================================================
# API key for ESP32 devices (optional default key)
DEFAULT_API_KEY="esp32-default-api-key-change-this"

# Session secret for additional security
SESSION_SECRET="your-session-secret-key"

# External Services (Optional)
# =============================================================================
# Firebase configuration for push notifications (optional)
FIREBASE_PROJECT_ID="your-firebase-project"
FIREBASE_CLIENT_EMAIL="your-service-account@firebase.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase private key\n-----END PRIVATE KEY-----\n"

# Analytics (optional)
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"

# Payment Integration (optional - for premium features)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Development Only
# =============================================================================
# Database connection pool settings (for heavy development)
DATABASE_POOL_SIZE=10

# Enable query logging
DATABASE_LOG_QUERIES=true

# =============================================================================
# How to set up your Neon Database:
# =============================================================================
# 1. Go to https://neon.tech and create an account
# 2. Create a new project
# 3. Copy your database connection string
# 4. Replace the DATABASE_URL and DIRECT_URL above with your connection string
# 
# Your Neon connection string format:
# postgresql://[user]:[password]@[endpoint]/[database]?sslmode=require
#
# Example:
# postgresql://alex:AbC123dEf@ep-cool-darkness-123456.us-east-1.aws.neon.tech/neondb?sslmode=require
# =============================================================================