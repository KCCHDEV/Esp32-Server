# 🚀 ESP32 Zero-Code Platform - Super Simple Setup!
# Only 4 environment variables needed for Netlify deployment

# 🔐 JWT Configuration (REQUIRED)
JWT_SECRET="your-super-secret-jwt-key-generate-with-crypto"
JWT_EXPIRE="7d"

# 🗄️ Neon Database URL (REQUIRED)
NETLIFY_DATABASE_URL="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"

# 🌐 Environment (AUTO-SET by Netlify)
NODE_ENV="production"

# 🚀 How to generate JWT_SECRET:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or visit: https://generate-secret.vercel.app/32

# 📝 Setup Steps:
# 1. Create Neon database at neon.tech (free)
# 2. Copy connection string to NETLIFY_DATABASE_URL
# 3. Generate random JWT_SECRET (32+ characters)
# 4. Set NODE_ENV to "production"
# 5. Deploy and visit /auto-setup