# ESP32 Zero-Code Platform - Environment Configuration
# เพียงแค่ 4 ตัวแปรนี้เท่านั้น!

# 🔐 JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-generate-with-crypto"
JWT_EXPIRE="7d"

# 🗄️ Neon Database URLs (Netlify will auto-set these via Neon extension)
NETLIFY_DATABASE_URL="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"
NETLIFY_DATABASE_URL_UNPOOLED="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"

# 🚀 Generate JWT_SECRET:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"