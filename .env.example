# ===========================================
# ESP32 Zero-Code Platform - Environment Setup
# ===========================================

# 🗄️ Neon Database Configuration
# Get your database URL from: https://neon.tech
DATABASE_URL="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"

# For Netlify deployment (Neon extension will provide these automatically)
NETLIFY_DATABASE_URL="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"
NETLIFY_DATABASE_URL_UNPOOLED="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"

# 🔐 JWT Secret Key
# Generate a secure random string for JWT token signing
# You can use: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-here-make-it-long-and-random"

# 🌐 Optional: CORS Origin (leave default for most setups)
CORS_ORIGIN="http://localhost:3000"

# ⚡ Optional: Server Port (default: 3001)
PORT=3001

# 📝 Optional: Node Environment (default: development)
NODE_ENV=development