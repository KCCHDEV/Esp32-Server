# ESP32 Zero-Code Platform - Production-Ready Configuration
# Minimal required environment variables for production deployment

# 🔐 JWT Configuration (REQUIRED)
JWT_SECRET="your-super-secret-jwt-key-generate-with-crypto"
JWT_EXPIRE="7d"

# 🗄️ Neon Database URLs (REQUIRED - Netlify will auto-set these via Neon extension)
NETLIFY_DATABASE_URL="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"
NETLIFY_DATABASE_URL_UNPOOLED="postgresql://username:password@your-endpoint.neon.tech/your-database?sslmode=require"

# 🌐 CORS Configuration (REQUIRED for production)
CORS_ORIGIN="https://your-domain.com"

# 📊 Optional: Monitoring & Logging
NODE_ENV="production"

# 💾 Optional: Backup Configuration
BACKUP_DIR="./backups"
BACKUP_ENCRYPTION_KEY="your-backup-encryption-key"

# 🚀 Generate secure keys:
# JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# BACKUP_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"