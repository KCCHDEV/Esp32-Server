PORT=3001

# Database (ใช้กับทั้ง Netlify และ self-host)
# Neon: ใช้ pooled + unpooled; PostgreSQL ธรรมดา: ใส่ URL เดียวกันทั้งสอง
DATABASE_URL="postgresql://username:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d
BCRYPT_ROUNDS=12

# Admin credentials
ADMIN_EMAIL=admin@esp32platform.com
ADMIN_PASSWORD=admin123change

# Rate limiting (ระบบจำนวนมาก: เพิ่ม MAX_REQUESTS ได้)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000

# Device API key cache TTL วินาที (ลด DB load เมื่ออุปกรณ์เยอะ)
DEVICE_CACHE_TTL_SEC=60

# Premium features
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email service (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# CORS origins (for production, set to your Netlify domain)
CORS_ORIGIN=http://localhost:3000
CORS_ORIGIN_PROD=https://your-app.netlify.app

# Environment
NODE_ENV=development

# Netlify specific
NETLIFY_DEV=false