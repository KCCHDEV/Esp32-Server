{
  "name": "esp32-zero-code-backend",
  "version": "1.0.0",
  "description": "Backend API for ESP32 zero-code platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run db:generate && echo 'Backend build complete'",
    "build:db": "npm run db:generate && node scripts/build-setup.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "node scripts/migrate.js",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:setup": "node scripts/migrate.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "crypto": "^1.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "prisma": "^5.7.0"
  }
}