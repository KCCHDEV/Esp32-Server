{
  "name": "esp32-zero-code-platform",
  "version": "1.0.0",
  "description": "Zero-code platform for ESP32 development with visual programming interface",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm run dev",
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ../netlify/functions && npm install",
    "build": "npm run build:database && npm run build:frontend",
    "build:database": "cd backend && npm run build:db",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start": "cd backend && npm start",
    "db:generate": "cd backend && npm run db:generate",
    "db:push": "cd backend && npm run db:push",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:studio": "cd backend && npm run db:studio",
    "db:seed": "cd backend && npm run db:seed",
    "deploy:netlify": "netlify deploy --prod",
    "dev:netlify": "netlify dev"
  },
  "keywords": ["esp32", "iot", "zero-code", "visual-programming", "arduino", "netlify"],
  "author": "ESP32 Zero Code Platform",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "netlify-cli": "^17.10.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}